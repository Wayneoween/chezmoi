{{ if eq .chezmoi.os "darwin" }}
# Regenerate Brewfile and store it in the user's home directory
function update_brewfile() {
  echo "Regenerating Brewfile in the home directory..."
  brew bundle dump --force --brews --casks --taps --no-vscode --no-go --file="$HOME/Brewfile"
  echo "Brewfile has been successfully regenerated."
}
{{ end }}
clean_branches() {
    # 1. Prune: Update local list of remote branches, removing those deleted on server
    echo "Fetching and pruning..."
    git fetch -p

    # 2. Identify: Find local branches where the upstream is marked [gone]
    # Use --format so we get the bare branch name, not the '*'/'+' marker
    # column that `git branch -vv` prints for the current/worktree branches.
    local branches_to_delete=$(git branch --format='%(refname:short) %(upstream:track)' | awk '$2 == "[gone]" {print $1}')

    if [[ -z "$branches_to_delete" ]]; then
        echo "No 'gone' branches found. (Are your remote branches deleted?)"
        return 0
    fi

    echo "Found the following branches that are deleted on remote:"
    echo "$branches_to_delete"
    echo ""

    # 3. Confirm and Destroy
    read "reply?Delete these branches? (y/N) "
    if [[ "$reply" =~ ^[Yy]$ ]]; then
        echo "$branches_to_delete" | xargs git branch -D
        echo "💥 Deleted."
    else
        echo "Aborted."
    fi
}
